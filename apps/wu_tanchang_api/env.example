# Copy this file to apps/wu_tanchang_api/.env and fill in the provider key.

# Choose: qwen or deepseek
# Controls the default provider for agent profiles (config.json agents.defaults.provider).
WU_API_MODEL_PROVIDER=qwen

# Optional path overrides
# WU_API_CONFIG=apps/wu_tanchang_api/config.json
# WU_API_ENV_FILE=apps/wu_tanchang_api/.env
# WU_API_WORKSPACE=apps/wu_tanchang_api/workspace

# NOTE: model names are configured in config.json (agents.list[].model or
# providers.*.default_model), not via environment variables.

# DashScope / Bailian OpenAI-compatible API
# Base URL is fixed in config.json:
# https://dashscope.aliyuncs.com/compatible-mode/v1
WU_DASHSCOPE_API_KEY=your-dashscope-api-key
WU_DASHSCOPE_MAX_TOKENS=20000
WU_DASHSCOPE_TIMEOUT_S=180
WU_DASHSCOPE_TEMPERATURE=0.2

# DeepSeek official OpenAI-compatible API
# Base URL is fixed in config.json:
# https://api.deepseek.com
WU_DEEPSEEK_API_KEY=your-deepseek-api-key
WU_DEEPSEEK_MAX_TOKENS=20000
WU_DEEPSEEK_TIMEOUT_S=180
WU_DEEPSEEK_TEMPERATURE=0.2
